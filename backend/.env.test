# Test Environment Configuration
NODE_ENV=test

# Test Database (use a separate test database)
DATABASE_URL="postgresql://postgres:password@localhost:5432/recipehub_test"

# JWT Configuration (use different secrets for testing)
JWT_SECRET="test-jwt-secret-key-for-testing-only"
JWT_REFRESH_SECRET="test-refresh-secret-key-for-testing-only"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Configuration
PORT=3002

# CORS Configuration
FRONTEND_URL="http://localhost:3000"

# Rate Limiting (more lenient for tests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Disable Redis for tests (optional)
# REDIS_URL=""

# Logging (minimal for tests)
LOG_LEVEL="error"