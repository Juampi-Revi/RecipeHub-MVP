# Backend Development Dockerfile
FROM node:20-alpine

# Install curl for health checks and OpenSSL 1.1 for Prisma
RUN apk add --no-cache curl
RUN apk add --no-cache --repository=http://dl-cdn.alpinelinux.org/alpine/v3.16/main openssl1.1-compat-dev || apk add --no-cache openssl-dev

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev dependencies)
RUN npm install

# Copy source code
COPY . .

# Clean Prisma cache and generate client
RUN rm -rf node_modules/.prisma
RUN npx prisma generate

# Expose port
EXPOSE 3001

# Start the application in development mode with hot reload
CMD ["npm", "run", "dev"]